auth:
  uri: "https://ident.services"
  client_id: "sync-account@yourdomain.com"
  client_secret: "your-sync-account-client-secret"
samedis:
  uri: "https://sync.samedis.care"
  api_version: "v4"
  tenant_id: "63f5c0491b57cc000df2b2c7"
paths:
  from_samedis: "data/from_samedis"
  to_samedis: "data/to_samedis"
sync:
  archive_to_samedis_csv_files: true
  device_types: false
  contacts: false
  device_models: true
  departments_download: false
  departments_upload: false
  locations_download: false
  locations_upload: false
  locations_room_placeholder: "Keine Raumzuordnung"
  inventories_download: false
  inventories_upload: false
  inventories_upload_fallback_by_device_number: false
  create_local_device_models_on_inventory_lookup: false
  inventories_upload_create_departments_on_the_fly: false
  inventories_upload_create_locations_on_the_fly: false
  tasks_download: false
  tasks_upload: false
  # if true: for failed maintenance tasks, send inventory_operation_status=limited_use in task payload
  tasks_upload_set_inventory_operation_status_on_failed_maintenance: false
  # tasks_upload expects <to_samedis>/tasks.csv with:
  # issue_number;inventory_device_number;issue_type;title;status;done_at;responsible_name;maintenance_passed;filename
  # optional legacy column: date (ignored on upload)
  # optional: test_result + test_comment + maintenance_type + one of document_filename|file_name|document_name|dateiname
  # required filename must exist in <to_samedis>/task_documents/<filename> (or .pdf added)
  # malfunction, maintenance, device_retired, recommission_device, occurrence, security_message
  task_download_types: maintenance
  task_archive_filter: true
  # _new, pending, in_progress, due_in_6week, elapsed, not_done
  task_download_status: done
  requests_download: false
  requests_upload: false
  trainings: false
logging:
  # 0: off 1: on 2: debug
  level: 1
  # 0: none 1: console 2: logfile 3: console & logfile
  mode: 2
http:
  valid_certificate: true
  proxy: ""
  proxy_username: ""
  proxy_password: ""
# choose excel, sql
import_mode: "sql"
import_file: "import/import.xlsx"
import_sql:
  # SqlServer, MySql, SQLite, Oracle
  database_type: SqlServer
  server: "your_server"
  port: "your_port"
  database: "your_database"
  username: "your_username"
  password: "your_password"
  allow_public_key_retrieval: true # Only applicable for MySQL
  staff_query: "import/_export_staff.sql"
